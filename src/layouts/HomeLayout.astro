---
import '@/styles/global.css';
import { homeConfig } from '@/config/homeConfig';
import { calculatorRegistry } from '@/config/calculatorRegistry';
import {
  generateWebSiteSchema,
  generateItemListSchema,
  generateOrganizationSchema,
  generateFAQSchema,
} from '@/utils/schemaGenerators';
import { adsConfig, adsEnabled } from '@/config/adsConfig';
import Header from '@/components/ui/Header.astro';
import Footer from '@/components/ui/Footer.astro';
import Analytics from '@/components/analytics/Analytics.astro';
import WebVitals from '@/components/analytics/WebVitals.astro';
import type { HomeCalculatorCard } from '@/types/home';

const baseUrl = import.meta.env.SITE ?? 'https://fincal.id';
const canonicalUrl = `${baseUrl}/`;
// TODO: Replace placeholder OG image with final branded asset.
const ogImage = `${baseUrl}/og/default.png`;

const calculators: HomeCalculatorCard[] = Object.values(calculatorRegistry)
  .map(({ slug, title, description, keywords, category, icon, order }) => ({
    slug,
    title,
    description,
    keywords,
    category,
    icon,
    order,
  }))
  .sort((a, b) => a.order - b.order);

const webSiteSchema = generateWebSiteSchema(baseUrl);
const itemListSchema = generateItemListSchema(calculators, baseUrl);
const organizationSchema = generateOrganizationSchema(baseUrl);
const faqSchema = generateFAQSchema(homeConfig.faqs);
---

<!doctype html>
<html lang="id" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{homeConfig.title}</title>
    <meta name="description" content={homeConfig.metaDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:title" content={homeConfig.title} />
    <meta property="og:description" content={homeConfig.metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={homeConfig.title} />
    <meta name="twitter:description" content={homeConfig.metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Schemas -->
    <script type="application/ld+json" set:html={webSiteSchema} />
    <script type="application/ld+json" set:html={itemListSchema} />
    <script type="application/ld+json" set:html={organizationSchema} />
    <script type="application/ld+json" set:html={faqSchema} />

    <!-- Theme: injected before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- GA4 -->
    <Analytics />

    <!-- AdSense: deferred until idle to protect LCP/INP -->
    {
      adsEnabled && (
        <script is:inline define:vars={{ adClient: adsConfig.client }}>
          (function () {
            function load() {
              if (document.querySelector('script[src*="adsbygoogle"]')) return;
              var s = document.createElement('script');
              s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js';
              s.async = true;
              s.crossOrigin = 'anonymous';
              s.setAttribute('data-ad-client', adClient);
              document.head.appendChild(s);
            }
            if ('requestIdleCallback' in window) {
              requestIdleCallback(load, { timeout: 3000 });
            } else {
              setTimeout(load, 2000);
            }
          })();
        </script>
      )
    }

    <style>
      :root {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
    <Header />
    <slot />
    <Footer />
    <WebVitals />
  </body>
</html>
