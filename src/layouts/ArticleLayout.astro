---
import '@/styles/global.css';
import Header from '@/components/ui/Header.astro';
import Footer from '@/components/ui/Footer.astro';
import Analytics from '@/components/analytics/Analytics.astro';
import WebVitals from '@/components/analytics/WebVitals.astro';
import Container from '@/components/ui/Container.astro';
import AdInArticle from '@/components/ads/AdInArticle.astro';
import AdBanner from '@/components/ads/AdBanner.astro';
import { adsConfig, adsEnabled } from '@/config/adsConfig';
import {
  generateArticleSchema,
  generateArticleBreadcrumbSchema,
} from '@/utils/schemaGenerators';
import { CATEGORY_COLORS, type ArticleCategory } from '@/constants/article';
import { articleIndexHref } from '@/utils/articleUrls';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  metaDescription: string;
  canonicalUrl: string;
  publishDate: Date;
  updatedDate?: Date;
  author: string;
  category: ArticleCategory;
  tags: string[];
  ogImage?: string;
  relatedCalculators?: string[];
  relatedArticle?: CollectionEntry<'article'>[];
}

const {
  title,
  metaDescription,
  canonicalUrl,
  publishDate,
  updatedDate,
  author,
  category,
  tags,
  ogImage,
  relatedArticle = [],
} = Astro.props;

const baseUrl = import.meta.env.SITE ?? 'https://fincal.id';
// TODO: Replace placeholder OG image with a per-article image or final branded default at public/og/default.png.
const resolvedOgImage = ogImage ?? `${baseUrl}/og/default.png`;
const publishedISO = publishDate.toISOString();
const updatedISO = (updatedDate ?? publishDate).toISOString();
const showUpdatedDate = updatedDate && updatedDate.getTime() > publishDate.getTime();

const articleSchema = generateArticleSchema({
  title,
  metaDescription,
  publishDate,
  updatedDate,
  author,
  canonicalUrl,
  ogImage: resolvedOgImage,
  baseUrl,
  articleSection: category,
  keywords: tags,
});
const breadcrumbSchema = generateArticleBreadcrumbSchema(title, canonicalUrl, baseUrl);
---

<!doctype html>
<html lang="id" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph (article type) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="article:published_time" content={publishedISO} />
    <meta property="article:modified_time" content={updatedISO} />
    <meta property="article:author" content={author} />
    <meta property="article:section" content={category} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />

    <!-- Theme: injected before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <Analytics />

    {
      adsEnabled && (
        <script is:inline define:vars={{ adClient: adsConfig.client }}>
          (function () {
            function load() {
              if (document.querySelector('script[src*="adsbygoogle"]')) return;
              var s = document.createElement('script');
              s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js';
              s.async = true;
              s.crossOrigin = 'anonymous';
              s.setAttribute('data-ad-client', adClient);
              document.head.appendChild(s);
            }
            if ('requestIdleCallback' in window) {
              requestIdleCallback(load, { timeout: 3000 });
            } else {
              setTimeout(load, 2000);
            }
          })();
        </script>
      )
    }

    <!-- Global: MDX/markdown renders through <slot /> and is not part of this
         file's scoped AST, so scoped .article-body h2 etc. would never match. -->
    <style is:global>
      :root {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .article-body h2 {
        font-size: 1.25rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: var(--tw-prose-headings, #111827);
      }
      .dark .article-body h2 { color: #f9fafb; }

      .article-body h3 {
        font-size: 1.05rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        color: var(--tw-prose-headings, #1f2937);
      }
      .dark .article-body h3 { color: #f3f4f6; }

      .article-body p { margin-bottom: 1rem; line-height: 1.75; }

      .article-body ul,
      .article-body ol {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
      }
      .article-body ul { list-style-type: disc; }
      .article-body ol { list-style-type: decimal; }
      .article-body li { margin-bottom: 0.375rem; line-height: 1.7; }

      .article-body a {
        color: #2563eb;
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .dark .article-body a { color: #60a5fa; }

      .article-body strong { font-weight: 600; }

      .article-body table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
      }
      .article-body th,
      .article-body td {
        border: 1px solid #e5e7eb;
        padding: 0.5rem 0.75rem;
        text-align: left;
      }
      .dark .article-body th,
      .dark .article-body td { border-color: #374151; }
      .article-body th {
        background: #f9fafb;
        font-weight: 600;
      }
      .dark .article-body th { background: #1f2937; }

      .article-body blockquote {
        border-left: 3px solid #2563eb;
        padding-left: 1rem;
        margin: 1.25rem 0;
        color: #4b5563;
        font-style: italic;
      }
      .dark .article-body blockquote { color: #9ca3af; }

      .article-body code {
        background: #f3f4f6;
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        font-size: 0.875em;
      }
      .dark .article-body code { background: #1f2937; }

      .article-body hr {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 2rem 0;
      }
      .dark .article-body hr { border-color: #374151; }
    </style>
  </head>

  <body class="min-h-screen bg-white text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
    <Header />

    {
      adsEnabled && (
        <div class="w-full border-b border-gray-100 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
          <Container>
            <AdBanner position="top" />
          </Container>
        </div>
      )
    }

    <main id="main-content">
      <Container class="py-8">
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_280px]">

          <!-- Article column -->
          <article>
            <!-- Breadcrumb -->
            <nav aria-label="Breadcrumb" class="mb-4">
              <ol class="flex flex-wrap items-center gap-1 text-xs text-gray-500 dark:text-gray-400"
                  itemscope itemtype="https://schema.org/BreadcrumbList">
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                  <a href="/" itemprop="item" class="transition-colors hover:text-brand-600 dark:hover:text-brand-400">
                    <span itemprop="name">Beranda</span>
                  </a>
                  <meta itemprop="position" content="1" />
                </li>
                <li aria-hidden="true" class="select-none">/</li>
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                  <a href="/artikel/" itemprop="item" class="transition-colors hover:text-brand-600 dark:hover:text-brand-400">
                    <span itemprop="name">Artikel</span>
                  </a>
                  <meta itemprop="position" content="2" />
                </li>
                <li aria-hidden="true" class="select-none">/</li>
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                  <span itemprop="name" aria-current="page"
                        class="font-medium text-gray-700 dark:text-gray-300 line-clamp-1">
                    {title}
                  </span>
                  <meta itemprop="position" content="3" />
                </li>
              </ol>
            </nav>

            <!-- Category + tags (filter links to article index) -->
            <div class="mb-3 flex flex-wrap items-center gap-2">
              <a
                href={`/artikel/?kategori=${encodeURIComponent(category)}`}
                class={`rounded-full px-2.5 py-0.5 text-xs font-semibold transition-opacity hover:opacity-90 ${CATEGORY_COLORS[category]}`}
              >
                {category}
              </a>
              {tags.map((tag) => (
                <a
                  href={articleIndexHref({ kategori: category, tag })}
                  class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
                >
                  {tag}
                </a>
              ))}
            </div>

            <!-- Title -->
            <h1 class="text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl dark:text-gray-50">
              {title}
            </h1>

            <!-- Meta row -->
            <div class="mt-3 mb-6 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-500 dark:text-gray-400 border-b border-gray-100 dark:border-gray-800 pb-5">
              <span>
                <svg class="mr-1 inline h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                </svg>
                {author}
              </span>
              <time datetime={publishedISO}>
                <svg class="mr-1 inline h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                </svg>
                {publishDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              {showUpdatedDate && (
                <span class="italic">
                  Diperbarui:{' '}
                  {updatedDate!.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
              )}
            </div>

            <AdInArticle />

            <!-- Article body -->
            <div class="article-body text-sm leading-relaxed text-gray-700 dark:text-gray-300">
              <slot />
            </div>

            <AdInArticle />

            <!-- Related calculators -->
            {Astro.props.relatedCalculators && Astro.props.relatedCalculators.length > 0 && (
              <div class="mt-10 rounded-xl border border-brand-100 bg-brand-50/50 p-5 dark:border-brand-900/30 dark:bg-brand-950/20">
                <p class="mb-3 text-sm font-semibold text-gray-900 dark:text-gray-100">
                  Coba Kalkulator Terkait
                </p>
                <div class="flex flex-wrap gap-2">
                  {Astro.props.relatedCalculators.map((slug: string) => (
                    <a
                      href={`/kalkulator/${slug}/`}
                      class="inline-flex items-center gap-1.5 rounded-lg border border-brand-200 bg-white px-3 py-1.5 text-xs font-medium text-brand-700 transition-colors hover:bg-brand-600 hover:text-white dark:border-brand-800 dark:bg-gray-900 dark:text-brand-300 dark:hover:bg-brand-700 dark:hover:text-white"
                    >
                      <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm2 10a1 1 0 10-2 0v3a1 1 0 102 0v-3zm2-3a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm4-1a1 1 0 10-2 0v7a1 1 0 102 0V8z" clip-rule="evenodd" />
                      </svg>
                      Kalkulator {slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
                    </a>
                  ))}
                </div>
              </div>
            )}

            <!-- Related articles -->
            {relatedArticle.length > 0 && (
              <div class="mt-10 border-t border-gray-100 pt-8 dark:border-gray-800">
                <h2 class="text-base font-bold text-gray-900 dark:text-gray-50">Artikel Terkait</h2>
                <ul class="mt-4 space-y-3">
                  {relatedArticle.map((item) => (
                    <li>
                      <a
                        href={`/artikel/${item.id}/`}
                        class="group flex flex-col gap-1 rounded-lg border border-gray-200 bg-white p-4 transition-all hover:border-brand-400 hover:shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:hover:border-brand-600"
                      >
                        <div class="flex flex-wrap items-center gap-2">
                          <span
                            class={`rounded-full px-2 py-0.5 text-[10px] font-semibold ${CATEGORY_COLORS[item.data.category]}`}
                          >
                            {item.data.category}
                          </span>
                          <time
                            datetime={item.data.publishDate.toISOString()}
                            class="text-[10px] text-gray-500 dark:text-gray-400"
                          >
                            {item.data.publishDate.toLocaleDateString('id-ID', {
                              day: 'numeric',
                              month: 'short',
                              year: 'numeric',
                            })}
                          </time>
                        </div>
                        <span class="text-sm font-semibold text-gray-900 transition-colors group-hover:text-brand-600 dark:text-gray-100 dark:group-hover:text-brand-400">
                          {item.data.title}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Back link -->
            <div class="mt-8 pt-6 border-t border-gray-100 dark:border-gray-800">
              <a
                href="/artikel/"
                class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 transition-colors hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
              >
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                </svg>
                Semua Artikel
              </a>
            </div>
          </article>

          <!-- Sidebar -->
          <aside class="hidden lg:block">
            <div class="sticky top-20 space-y-6">
              <!-- CTA card -->
              <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 dark:border-gray-800 dark:bg-gray-900">
                <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">
                  Coba Kalkulator Gratis
                </p>
                <p class="mt-1 text-xs leading-relaxed text-gray-600 dark:text-gray-400">
                  Simulasikan KPR, kredit kendaraan, pajak, zakat, dan investasi — akurat dan tanpa registrasi.
                </p>
                <a
                  href="/kalkulator/"
                  class="mt-3 flex items-center justify-center gap-1 rounded-lg bg-brand-600 px-4 py-2 text-xs font-semibold text-white transition-colors hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600"
                >
                  Lihat Semua Kalkulator
                </a>
              </div>

              <AdBanner position="sidebar" />
            </div>
          </aside>

        </div>
      </Container>
    </main>

    <Footer />
    <WebVitals />
  </body>
</html>
