---
import '@/styles/global.css';
import type { CalculatorConfig } from '@/types/calculator';
import {
  generateBreadcrumbSchema,
  generateFAQSchema,
  generateSoftwareAppSchema,
  generateHowToSchema,
} from '@/utils/schemaGenerators';
import { adsConfig } from '@/config/adsConfig';
import Header from '@/components/ui/Header.astro';
import Footer from '@/components/ui/Footer.astro';
import Analytics from '@/components/analytics/Analytics.astro';
import WebVitals from '@/components/analytics/WebVitals.astro';
import Container from '@/components/ui/Container.astro';
// TODO: uncomment when AdSense is ready
// import AdBanner from '@/components/ads/AdBanner.astro';
// import AdInArticle from '@/components/ads/AdInArticle.astro';
import Breadcrumb from '@/components/seo/Breadcrumb.astro';
import FAQSection from '@/components/seo/FAQSection.astro';
import MethodSection from '@/components/seo/MethodSection.astro';
import RelatedCalculators from '@/components/ui/RelatedCalculators.astro';

interface Props {
  title: string;
  metaDescription: string;
  canonicalUrl: string;
  calculatorConfig: CalculatorConfig;
  ogImage?: string;
}

const { title, metaDescription, canonicalUrl, calculatorConfig, ogImage } = Astro.props;

const baseUrl = new URL(canonicalUrl).origin;
const resolvedOgImage = ogImage ?? `/og/${calculatorConfig.slug}.png`;

const breadcrumbSchema = generateBreadcrumbSchema(calculatorConfig, baseUrl);
const faqSchema = generateFAQSchema(calculatorConfig.faqs);
const softwareAppSchema = generateSoftwareAppSchema(calculatorConfig, baseUrl);
const howToSchema = generateHowToSchema(calculatorConfig);

const hasLongContent = calculatorConfig.seoContent.length > 600;
---

<!doctype html>
<html lang="id" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- JSON-LD Schemas -->
    <script type="application/ld+json" set:html={breadcrumbSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
    <script type="application/ld+json" set:html={softwareAppSchema} />
    <script type="application/ld+json" set:html={howToSchema} />

    <!-- Theme: injected before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- GA4 via Partytown (off main thread) -->
    <Analytics />

    <!-- AdSense: deferred until idle to protect LCP/INP -->
    <script is:inline define:vars={{ adClient: adsConfig.client }}>
      (function () {
        function load() {
          if (document.querySelector('script[src*="adsbygoogle"]')) return;
          var s = document.createElement('script');
          s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js';
          s.async = true;
          s.crossOrigin = 'anonymous';
          s.setAttribute('data-ad-client', adClient);
          document.head.appendChild(s);
        }
        if ('requestIdleCallback' in window) {
          requestIdleCallback(load, { timeout: 3000 });
        } else {
          setTimeout(load, 2000);
        }
      })();
    </script>

    <!-- Fonts: system stack (no web font request = faster LCP) -->
    <style>
      :root {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
    <Header />

    <!-- Top ad: fixed min-height reserves space before AdSense loads (prevents CLS) -->
    <div class="w-full border-b border-gray-100 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
      <!-- TODO: uncomment when AdSense is ready -->
      <!-- <AdBanner position="top" /> -->
    </div>

    <main id="main-content">
      <Container>
        <div class="grid grid-cols-1 gap-8 py-8 lg:grid-cols-[1fr_300px]">
          <!-- Main article column -->
          <article>
            <Breadcrumb config={calculatorConfig} />

            <h1
              class="mt-4 mb-3 text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-gray-50"
            >
              {title}
            </h1>
            <p class="mb-6 text-base leading-relaxed text-gray-600 dark:text-gray-400">
              {calculatorConfig.description}
            </p>

            <!-- TODO: uncomment when AdSense is ready -->
            <!-- <AdInArticle /> -->

            <!-- React calculator island: injected by the page via slot -->
            <slot />

            <div class="mt-8">
              <!-- TODO: uncomment when AdSense is ready -->
              <!-- <AdInArticle /> -->
            </div>

            <!-- SEO content: fully server-rendered, zero hydration -->
            <section
              class="prose-content mt-10 text-sm leading-relaxed text-gray-700 dark:text-gray-300"
              set:html={calculatorConfig.seoContent}
            />

            <!-- TODO: uncomment when AdSense is ready -->
            <!-- {hasLongContent && <AdInArticle />} -->

            <FAQSection faqs={calculatorConfig.faqs} />
            <MethodSection sources={calculatorConfig.methodSection} />
            <RelatedCalculators slugs={calculatorConfig.relatedCalculators} />
          </article>

          <!-- Sidebar: desktop only, sticky ad -->
          <aside class="hidden lg:block">
            {
              hasLongContent && (
                <div class="sticky top-4">
                  {/* TODO: uncomment when AdSense is ready */}
                  {/* <AdBanner position="sidebar" /> */}
                </div>
              )
            }
          </aside>
        </div>
      </Container>
    </main>

    <Footer />
    <WebVitals />
  </body>
</html>
