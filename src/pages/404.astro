---
import "@/styles/global.css";
import Header from "@/components/ui/Header.astro";
import Footer from "@/components/ui/Footer.astro";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Halaman Tidak Ditemukan | FinCal</title>
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline>
      (function () {
        var saved = localStorage.getItem("theme");
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        if (saved === "dark" || (!saved && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen antialiased flex flex-col"
  >
    <Header />

    <main class="flex-1 flex items-center justify-center px-4 py-16">
      <div class="text-center max-w-md">
        <p class="text-6xl font-bold text-blue-500 dark:text-blue-400 mb-4">
          404
        </p>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-50 mb-2">
          Halaman tidak ditemukan
        </h1>
        <p class="text-gray-600 dark:text-gray-400 text-sm mb-8">
          URL yang Anda buka tidak ada atau telah dipindahkan.
        </p>
        <a
          href="/"
          class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition-colors"
        >
          Kembali ke Beranda
        </a>
      </div>
    </main>

    <Footer />
  </body>
</html>
