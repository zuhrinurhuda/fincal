---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getRelatedArticle } from '@/utils/relatedArticle';

export async function getStaticPaths() {
  const posts = await getCollection('article');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allArticle = await getCollection('article');
const relatedArticle = getRelatedArticle(allArticle, post, post.data.relatedArticles);

const baseUrl = import.meta.env.SITE ?? 'https://fincal.id';
const canonicalUrl = `${baseUrl}/artikel/${post.id}/`;
---

<ArticleLayout
  title={post.data.title}
  metaDescription={post.data.metaDescription}
  canonicalUrl={canonicalUrl}
  publishDate={post.data.publishDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  category={post.data.category}
  tags={post.data.tags}
  ogImage={post.data.ogImage}
  relatedCalculators={post.data.relatedCalculators}
  relatedArticle={relatedArticle}
>
  <Content />
</ArticleLayout>
