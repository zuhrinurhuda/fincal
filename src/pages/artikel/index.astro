---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import AdBanner from '@/components/ads/AdBanner.astro';
import FAQSection from '@/components/seo/FAQSection.astro';
import ArticleGrid from '@/components/article/ArticleGrid';
import { adsConfig, adsEnabled } from '@/config/adsConfig';
import {
  generateArticleIndexBreadcrumbSchema,
  generateArticleItemListSchema,
  generateArticleCollectionPageSchema,
  generateFAQSchema,
} from '@/utils/schemaGenerators';
import type { FAQItem } from '@/types/calculator';
import type { ArticleListCard } from '@/types/article';

const baseUrl = import.meta.env.SITE ?? 'https://fincal.id';
const canonicalUrl = `${baseUrl}/artikel/`;

const pageDescription =
  'Panduan keuangan praktis untuk masyarakat Indonesia — KPR, kredit, pajak, investasi, dan zakat. Artikel informatif yang membantu Anda membuat keputusan finansial yang lebih baik.';

const allArticle = await getCollection('article');
const sorted = allArticle.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const articleCards: ArticleListCard[] = sorted.map((post) => ({
  id: post.id,
  title: post.data.title,
  metaDescription: post.data.metaDescription,
  category: post.data.category,
  tags: post.data.tags,
  publishDate: post.data.publishDate.toISOString(),
  featured: post.data.featured,
}));

const articleListForSchema = sorted.map((p) => ({ id: p.id, title: p.data.title }));

const faqs: FAQItem[] = [
  {
    question: 'Apa topik yang dibahas di artikel FinCal?',
    answer:
      'Kami membahas panduan keuangan praktis untuk masyarakat Indonesia — mulai dari cara hitung cicilan KPR, perbedaan bunga flat dan efektif, panduan PPh 21, tips investasi, hingga kalkulator zakat.',
  },
  {
    question: 'Apakah artikel di FinCal gratis dibaca?',
    answer: 'Ya, semua artikel di FinCal 100% gratis tanpa perlu registrasi atau membuat akun.',
  },
  {
    question: 'Seberapa sering FinCal menerbitkan artikel baru?',
    answer:
      'Kami berusaha menerbitkan artikel baru secara rutin. Setiap artikel juga diperbarui bila ada perubahan regulasi yang relevan.',
  },
];

const breadcrumbSchema = generateArticleIndexBreadcrumbSchema(baseUrl);
const itemListSchema = generateArticleItemListSchema(articleListForSchema, baseUrl);
const collectionPageSchema = generateArticleCollectionPageSchema(baseUrl, pageDescription);
const faqSchema = generateFAQSchema(faqs);
---

<PageLayout
  title="Artikel & Panduan Keuangan Indonesia | FinCal"
  metaDescription={pageDescription}
  canonicalUrl={canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbSchema} />
    <script type="application/ld+json" set:html={collectionPageSchema} />
    <script type="application/ld+json" set:html={itemListSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
  </Fragment>

  <div class="w-full border-b border-gray-100 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
    <AdBanner position="top" />
  </div>

  <main id="main-content">
    <Container class="py-6">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol
          class="flex flex-wrap items-center gap-1 text-xs text-gray-500 dark:text-gray-400"
          itemscope
          itemtype="https://schema.org/BreadcrumbList"
        >
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a
              href="/"
              itemprop="item"
              class="transition-colors hover:text-brand-600 dark:hover:text-brand-400"
            >
              <span itemprop="name">Beranda</span>
            </a>
            <meta itemprop="position" content="1" />
          </li>
          <li aria-hidden="true" class="select-none">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span
              itemprop="name"
              aria-current="page"
              class="font-medium text-gray-700 dark:text-gray-300"
            >
              Artikel
            </span>
            <meta itemprop="position" content="2" />
          </li>
        </ol>
      </nav>

      <h1
        class="text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl dark:text-gray-50"
      >
        Artikel & Panduan Keuangan
      </h1>
      <p class="mt-2 mb-6 max-w-2xl text-base leading-relaxed text-gray-600 dark:text-gray-400">
        Panduan praktis seputar KPR, kredit, pajak, investasi, dan zakat — ditulis khusus untuk
        pembaca Indonesia. Gunakan pencarian dan filter kategori untuk menemukan topik yang Anda
        butuhkan.
      </p>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_300px]">
        <div>
          <ArticleGrid
            posts={articleCards}
            adClient={adsConfig.client}
            adSlotInFeed={adsConfig.slots.inFeed}
            adsEnabled={adsEnabled}
            client:load
          />

          <noscript>
            <nav
              aria-label="Daftar artikel"
              class="mt-6 border-t border-gray-100 pt-6 dark:border-gray-800"
            >
              <p class="mb-3 text-sm font-medium text-gray-700 dark:text-gray-200">
                Aktifkan JavaScript untuk filter dan urutan, atau buka artikel di bawah ini:
              </p>
              <ul class="space-y-2 text-sm">
                {
                  sorted.map((post) => (
                    <li>
                      <a
                        href={`/artikel/${post.id}/`}
                        class="text-brand-600 underline-offset-2 hover:underline dark:text-brand-400"
                      >
                        {post.data.title}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </nav>
          </noscript>
        </div>

        <aside class="hidden lg:block">
          <div class="sticky top-20 space-y-6">
            <div
              class="rounded-xl border border-gray-200 bg-gray-50 p-5 dark:border-gray-800 dark:bg-gray-900"
            >
              <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">
                Coba Kalkulator Gratis
              </p>
              <p class="mt-1 text-xs leading-relaxed text-gray-600 dark:text-gray-400">
                Simulasikan KPR, kredit kendaraan, pajak, zakat, dan investasi — akurat dan tanpa
                registrasi.
              </p>
              <a
                href="/kalkulator/"
                class="mt-3 flex items-center justify-center rounded-lg bg-brand-600 px-4 py-2 text-xs font-semibold text-white transition-colors hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600"
              >
                Lihat Semua Kalkulator
              </a>
            </div>

            <AdBanner position="sidebar" />
          </div>
        </aside>
      </div>

      <FAQSection faqs={faqs} />
    </Container>
  </main>
</PageLayout>
