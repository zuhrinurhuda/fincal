---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import HeroSection from '@/components/home/HeroSection.astro';
import FAQSection from '@/components/seo/FAQSection.astro';
import { calculatorRegistry } from '@/config/calculatorRegistry';
import { homeConfig } from '@/config/homeConfig';
import {
  generateWebSiteSchema,
  generateOrganizationSchema,
  generateFAQSchema,
} from '@/utils/schemaGenerators';
import type { HomeCalculatorCard } from '@/types/home';

const baseUrl = import.meta.env.SITE ?? 'https://fincal.id';
const canonicalUrl = `${baseUrl}/`;

const calculators: HomeCalculatorCard[] = Object.values(calculatorRegistry)
  .map(({ slug, title, description, keywords, category, icon, order }) => ({
    slug,
    title,
    description,
    keywords,
    category,
    icon,
    order,
  }))
  .sort((a, b) => a.order - b.order);

const featured = calculators.slice(0, 4);

const webSiteSchema = generateWebSiteSchema(baseUrl);
const organizationSchema = generateOrganizationSchema(baseUrl);
const faqSchema = generateFAQSchema(homeConfig.faqs);

const CATEGORY_COLORS: Record<string, { bg: string; text: string; icon: string }> = {
  blue: {
    bg: 'bg-blue-50 dark:bg-blue-950/30',
    text: 'text-blue-700 dark:text-blue-300',
    icon: 'bg-blue-100 text-blue-600 dark:bg-blue-900/50 dark:text-blue-400',
  },
  emerald: {
    bg: 'bg-emerald-50 dark:bg-emerald-950/30',
    text: 'text-emerald-700 dark:text-emerald-300',
    icon: 'bg-emerald-100 text-emerald-600 dark:bg-emerald-900/50 dark:text-emerald-400',
  },
  amber: {
    bg: 'bg-amber-50 dark:bg-amber-950/30',
    text: 'text-amber-700 dark:text-amber-300',
    icon: 'bg-amber-100 text-amber-600 dark:bg-amber-900/50 dark:text-amber-400',
  },
};

const CATEGORY_ICON_COLORS: Record<string, string> = {
  Kredit: 'bg-blue-100 text-blue-600 dark:bg-blue-900/50 dark:text-blue-400',
  Investasi: 'bg-emerald-100 text-emerald-600 dark:bg-emerald-900/50 dark:text-emerald-400',
  'Pajak & Zakat': 'bg-amber-100 text-amber-600 dark:bg-amber-900/50 dark:text-amber-400',
};

const VP_ICONS: Record<string, string> = {
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  zap: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  lock: 'M19 11H5a2 2 0 00-2 2v7a2 2 0 002 2h14a2 2 0 002-2v-7a2 2 0 00-2-2zM7 11V7a5 5 0 0110 0v4',
  device: 'M12 18h.01M8 2h8a2 2 0 012 2v16a2 2 0 01-2 2H8a2 2 0 01-2-2V4a2 2 0 012-2z',
};
---

<PageLayout
  title={homeConfig.title}
  metaDescription={homeConfig.metaDescription}
  canonicalUrl={canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={webSiteSchema} />
    <script type="application/ld+json" set:html={organizationSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
  </Fragment>

  <HeroSection />

  <!-- Top ad banner -->
  <div class="w-full border-b border-gray-100 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
    <!-- TODO: uncomment when AdSense is ready -->
    <!-- <AdBanner position="top" /> -->
  </div>

  <main id="main-content">
    <!-- Featured calculators -->
    <section class="py-12">
      <Container>
        <h2 class="text-xl font-bold tracking-tight text-gray-900 sm:text-2xl dark:text-gray-50">
          Kalkulator Populer
        </h2>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
          Paling sering digunakan oleh pengguna FinCal.
        </p>

        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {featured.map((calc) => (
            <a
              href={`/kalkulator/${calc.slug}/`}
              class="group flex flex-col rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-blue-400 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-blue-600"
            >
              <div class="mb-3 flex items-center gap-3">
                <div
                  class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-lg ${CATEGORY_ICON_COLORS[calc.category] ?? ''}`}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M23 6l-9.5 9.5-5-5L1 18M23 6h-6m6 0v6" />
                  </svg>
                </div>
                <h3 class="text-sm font-semibold text-gray-900 transition-colors group-hover:text-blue-600 dark:text-gray-100 dark:group-hover:text-blue-400">
                  {calc.title}
                </h3>
              </div>
              <p class="flex-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">
                {calc.description}
              </p>
              <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-blue-600 dark:text-blue-400">
                Hitung sekarang
                <svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
              </span>
            </a>
          ))}
        </div>

        <div class="mt-6 text-center">
          <a
            href="/kalkulator/"
            class="inline-flex items-center gap-1 text-sm font-medium text-blue-600 transition-colors hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
          >
            Lihat semua {calculators.length} kalkulator
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </Container>
    </section>

    <!-- Category overview -->
    <section class="border-t border-gray-100 bg-gray-50/50 py-12 dark:border-gray-800 dark:bg-gray-900/30">
      <Container>
        <h2 class="text-xl font-bold tracking-tight text-gray-900 sm:text-2xl dark:text-gray-50">
          Kategori Kalkulator
        </h2>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
          Pilih kategori untuk menemukan kalkulator yang tepat.
        </p>

        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
          {homeConfig.categories.map((cat) => {
            const colors = CATEGORY_COLORS[cat.color];
            const count = calculators.filter((c) => c.category === cat.filter).length;
            return (
              <a
                href="/kalkulator/"
                class={`group rounded-xl border border-gray-200 p-6 transition-all hover:shadow-md dark:border-gray-800 ${colors?.bg ?? ''}`}
              >
                <h3 class={`text-base font-bold ${colors?.text ?? ''}`}>{cat.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
                  {cat.description}
                </p>
                <p class="mt-3 text-xs font-medium text-gray-500 dark:text-gray-400">
                  {count} kalkulator tersedia
                </p>
              </a>
            );
          })}
        </div>
      </Container>
    </section>

    <!-- Value propositions -->
    <section class="py-12">
      <Container>
        <h2 class="text-xl font-bold tracking-tight text-gray-900 sm:text-2xl dark:text-gray-50">
          Mengapa Menggunakan FinCal?
        </h2>

        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {homeConfig.valuePropositions.map((vp) => (
            <div class="flex flex-col items-start">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/50 dark:text-blue-400">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={VP_ICONS[vp.icon] ?? VP_ICONS['shield']} />
                </svg>
              </div>
              <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">
                {vp.title}
              </h3>
              <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">
                {vp.description}
              </p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- SEO content + FAQ with sidebar -->
    <section class="border-t border-gray-100 py-12 dark:border-gray-800">
      <Container>
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_300px]">
          <div>
            <!-- SEO content -->
            <div
              class="prose-content text-sm leading-relaxed text-gray-700 dark:text-gray-300"
              set:html={homeConfig.seoContent}
            />

            <!-- TODO: uncomment when AdSense is ready -->
            <!-- <AdInArticle /> -->

            <FAQSection faqs={homeConfig.faqs} />
          </div>

          <!-- Sidebar -->
          <aside class="hidden lg:block">
            <div class="sticky top-20">
              <!-- TODO: uncomment when AdSense is ready -->
              <!-- <AdBanner position="sidebar" /> -->
            </div>
          </aside>
        </div>
      </Container>
    </section>

    <!-- Final CTA -->
    <section class="border-t border-gray-100 bg-blue-50/50 py-12 dark:border-gray-800 dark:bg-blue-950/10">
      <Container>
        <div class="text-center">
          <h2 class="text-xl font-bold tracking-tight text-gray-900 sm:text-2xl dark:text-gray-50">
            Mulai Hitung Sekarang
          </h2>
          <p class="mx-auto mt-2 max-w-lg text-sm text-gray-600 dark:text-gray-400">
            Gratis, tanpa registrasi, dan langsung dapat hasilnya. Pilih kalkulator yang Anda butuhkan.
          </p>
          <div class="mt-5">
            <a
              href="/kalkulator/"
              class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700 focus:ring-2 focus:ring-blue-500/40 focus:outline-none dark:bg-blue-500 dark:hover:bg-blue-600"
            >
              Lihat Semua Kalkulator
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </Container>
    </section>
  </main>
</PageLayout>
