---
import { adsConfig } from "../../config/adsConfig";
import AdBanner from "../ads/AdBanner.astro";

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
  <!-- Footer ad -->
  <AdBanner position="footer" />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="font-semibold text-gray-900 dark:text-gray-100 mb-1">FinCal</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 max-w-md leading-relaxed">
          Kalkulator keuangan gratis untuk masyarakat Indonesia. Hasil kalkulasi
          bersifat estimasi dan tidak merupakan saran keuangan profesional.
          Konsultasikan dengan perencana keuangan atau bank untuk keputusan
          finansial penting.
        </p>
      </div>
      <nav
        class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-gray-500 dark:text-gray-400"
        aria-label="Tautan footer"
      >
        <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
          Beranda
        </a>
        <a href="/kebijakan-privasi" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
          Kebijakan Privasi
        </a>
        <a href="/disclaimer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
          Disclaimer
        </a>
      </nav>
    </div>
    <p class="mt-6 text-xs text-gray-400 dark:text-gray-600">
      &copy; {year} FinCal. Semua hak dilindungi.
    </p>
  </div>
</footer>
