---
import { adsConfig } from '@/config/adsConfig';
import AdBanner from '@/components/ads/AdBanner.astro';

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
  <!-- Footer ad -->
  <AdBanner position="footer" />

  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <div>
        <p class="mb-1 font-semibold text-gray-900 dark:text-gray-100">FinCal</p>
        <p class="max-w-md text-xs leading-relaxed text-gray-500 dark:text-gray-400">
          Kalkulator keuangan gratis untuk masyarakat Indonesia. Hasil kalkulasi bersifat estimasi
          dan tidak merupakan saran keuangan profesional. Konsultasikan dengan perencana keuangan
          atau bank untuk keputusan finansial penting.
        </p>
      </div>
      <nav
        class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-gray-500 dark:text-gray-400"
        aria-label="Tautan footer"
      >
        <a href="/" class="transition-colors hover:text-blue-600 dark:hover:text-blue-400">
          Beranda
        </a>
        <a
          href="/kalkulator/"
          class="transition-colors hover:text-blue-600 dark:hover:text-blue-400"
        >
          Kalkulator
        </a>
        <a
          href="/kebijakan-privasi"
          class="transition-colors hover:text-blue-600 dark:hover:text-blue-400"
        >
          Kebijakan Privasi
        </a>
        <a
          href="/disclaimer"
          class="transition-colors hover:text-blue-600 dark:hover:text-blue-400"
        >
          Disclaimer
        </a>
      </nav>
    </div>
    <p class="mt-6 text-xs text-gray-400 dark:text-gray-600">
      &copy; {year} FinCal. Semua hak dilindungi.
    </p>
  </div>
</footer>
