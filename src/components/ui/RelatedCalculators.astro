---
import { calculatorRegistry } from '@/config/calculatorRegistry';

interface Props {
  slugs: string[];
}

const { slugs } = Astro.props;

const related = slugs.map((slug) => calculatorRegistry[slug]).filter(Boolean);
---

{
  related.length > 0 && (
    <section class="mt-10" aria-labelledby="related-heading">
      <h2 id="related-heading" class="mb-4 text-xl font-bold text-gray-900 dark:text-gray-50">
        Kalkulator Terkait
      </h2>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {related.map((config) => (
          <a
            href={`/kalkulator/${config.slug}/`}
            class="group flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4 transition-all hover:border-brand-400 hover:shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:hover:border-brand-600"
          >
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-950/50 dark:text-brand-400">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="16" height="16" x="4" y="4" rx="2" />
                <path d="M9 9h.01M15 9h.01M9 15h6" />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium text-gray-900 transition-colors group-hover:text-brand-600 dark:text-gray-100 dark:group-hover:text-brand-400">
                {config.title}
              </p>
              <p class="mt-0.5 truncate text-xs text-gray-500 dark:text-gray-400">
                {config.description}
              </p>
            </div>
            <svg
              class="h-4 w-4 shrink-0 text-gray-300 transition-colors group-hover:text-brand-400 dark:text-gray-600 dark:group-hover:text-brand-500"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        ))}
      </div>
    </section>
  )
}
