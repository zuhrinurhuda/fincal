---
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
---

<header
  class="sticky top-0 z-50 w-full border-b border-gray-200 bg-white/90 backdrop-blur dark:border-gray-800 dark:bg-gray-950/90"
>
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6">
    <!-- Logo -->
    <a
      href="/"
      class="text-brand-600 dark:text-brand-400 flex items-center gap-2 text-lg font-bold transition-opacity hover:opacity-80"
      aria-label="FinCal – Kalkulator Keuangan Indonesia"
    >
      <!-- <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
        class="shrink-0"
      >
        <rect width="24" height="24" rx="6" fill="currentColor" opacity="0.15"></rect>
        <path
          d="M7 8h10M7 12h6M7 16h8"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg> -->
      FinCal
    </a>

    <!-- Nav + theme toggle -->
    <nav class="flex items-center gap-0.5 sm:gap-1" aria-label="Navigasi utama">
      <a
        href="/kalkulator/"
        class="rounded-md px-2 py-1 text-xs text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900 sm:px-3 sm:py-1.5 sm:text-sm dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-100"
      >
        Kalkulator
      </a>
      <a
        href="/artikel/"
        class="rounded-md px-2 py-1 text-xs text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900 sm:px-3 sm:py-1.5 sm:text-sm dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-100"
      >
        Artikel
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
