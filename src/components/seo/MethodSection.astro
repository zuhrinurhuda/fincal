---
import type { MethodSource } from '@/types/calculator';

interface Props {
  sources: MethodSource[];
}

const { sources } = Astro.props;
---

<section class="mt-10" aria-labelledby="method-heading">
  <h2 id="method-heading" class="mb-4 text-xl font-bold text-gray-900 dark:text-gray-50">
    Metode Perhitungan & Sumber Referensi
  </h2>

  <div
    class="space-y-3 rounded-xl border border-blue-100 bg-blue-50/50 px-5 py-4 dark:border-blue-900/40 dark:bg-blue-950/20"
  >
    <p class="text-xs font-medium tracking-wide text-blue-700 uppercase dark:text-blue-400">
      Dasar Hukum & Regulasi
    </p>

    <ul class="space-y-3">
      {
        sources.map((src) => (
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-blue-500 dark:text-blue-400"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                clip-rule="evenodd"
              />
            </svg>
            <div class="text-sm">
              <span class="font-medium text-gray-900 dark:text-gray-100">{src.label}:</span>{' '}
              {src.url ? (
                <a
                  href={src.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-blue-600 hover:underline dark:text-blue-400"
                >
                  {src.source}
                </a>
              ) : (
                <span class="text-gray-600 dark:text-gray-400">{src.source}</span>
              )}
            </div>
          </li>
        ))
      }
    </ul>

    <p
      class="border-t border-blue-100 pt-1 text-xs text-gray-500 dark:border-blue-900/30 dark:text-gray-400"
    >
      Hasil kalkulator bersifat estimasi. Konsultasikan dengan bank atau penasihat keuangan untuk
      keputusan finansial yang tepat.
    </p>
  </div>
</section>
