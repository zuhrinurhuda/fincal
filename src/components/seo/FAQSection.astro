---
import type { FAQItem } from "../../types/calculator";

interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;
---

<section class="mt-10" aria-labelledby="faq-heading">
  <h2
    id="faq-heading"
    class="text-xl font-bold text-gray-900 dark:text-gray-50 mb-5"
  >
    Pertanyaan yang Sering Ditanyakan
  </h2>

  <div class="space-y-3">
    {
      faqs.map((faq, index) => (
        <details
          class="group rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden"
          name="faq"
        >
          <summary
            class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer list-none select-none font-medium text-sm text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
            id={`faq-q-${index}`}
          >
            <span>{faq.question}</span>
            <!-- Chevron icon that rotates when open -->
            <svg
              class="shrink-0 w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform duration-200"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"
              />
            </svg>
          </summary>

          <div class="px-5 pb-5 pt-1">
            <p
              class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed"
              id={`faq-a-${index}`}
            >
              {faq.answer}
            </p>
          </div>
        </details>
      ))
    }
  </div>
</section>
