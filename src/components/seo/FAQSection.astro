---
import type { FAQItem } from '@/types/calculator';

interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;
---

<section class="mt-10" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="mb-5 text-xl font-bold text-gray-900 dark:text-gray-50">
    Pertanyaan yang Sering Ditanyakan
  </h2>

  <div class="space-y-3">
    {
      faqs.map((faq, index) => (
        <details
          class="group overflow-hidden rounded-xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900"
          name="faq"
        >
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3 px-5 py-4 text-sm font-medium text-gray-900 transition-colors select-none hover:bg-gray-50 dark:text-gray-100 dark:hover:bg-gray-800/50"
            id={`faq-q-${index}`}
          >
            <span>{faq.question}</span>
            <svg
              class="h-4 w-4 shrink-0 text-gray-400 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                clip-rule="evenodd"
              />
            </svg>
          </summary>

          <div class="px-5 pt-1 pb-5">
            <p
              class="text-sm leading-relaxed text-gray-600 dark:text-gray-400"
              id={`faq-a-${index}`}
            >
              {faq.answer}
            </p>
          </div>
        </details>
      ))
    }
  </div>
</section>
