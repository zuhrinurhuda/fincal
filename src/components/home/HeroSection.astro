---
import { homeConfig } from '@/config/homeConfig';
---

<section
  class="border-b border-gray-100 bg-linear-to-b from-blue-50/60 to-white pt-12 pb-10 dark:border-gray-800 dark:from-blue-950/20 dark:to-gray-950"
>
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <h1
      class="text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl lg:text-4xl dark:text-gray-50"
    >
      {homeConfig.h1}
    </h1>
    <p
      class="mx-auto mt-3 max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg dark:text-gray-400"
    >
      {homeConfig.subtitle}
    </p>
    <div class="mt-6">
      <a
        href="/kalkulator/"
        class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700 focus:ring-2 focus:ring-blue-500/40 focus:outline-none dark:bg-blue-500 dark:hover:bg-blue-600"
      >
        Lihat Semua Kalkulator
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
