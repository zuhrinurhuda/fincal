---
import { homeConfig } from '@/config/homeConfig';
---

<section
  class="border-b border-gray-100 bg-linear-to-b from-blue-50/60 to-white pt-10 pb-8 dark:border-gray-800 dark:from-blue-950/20 dark:to-gray-950"
>
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <h1
      class="text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl lg:text-4xl dark:text-gray-50"
    >
      {homeConfig.h1}
    </h1>
    <p
      class="mx-auto mt-3 max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg dark:text-gray-400"
    >
      {homeConfig.subtitle}
    </p>
  </div>
</section>
