{
	"compatibility_date": "2026-03-19",
  "compatibility_flags": [
		"global_fetch_strictly_public",
    "nodejs_compat",
  ],
	// "main": "dist/_worker.js/index.js",
	"name": "fincal",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
    "enabled": true
  }
}